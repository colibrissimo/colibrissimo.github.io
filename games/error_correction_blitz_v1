      {t:'a',adj:false}, {t:'huge',adj:true,error:false,cat:'Size'},
      {t:'transparent',adj:true,error:true,cat:'Colour'}, {t:'old',adj:true,error:false,cat:'Age'},
      {t:'visor',adj:false}
