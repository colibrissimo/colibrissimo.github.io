<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>CYE · OSASCOMP · Error Correction Blitz</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --teal: #0891b2;
  --teal-glow: rgba(8,145,178,0.3);
  --orange: #f97316;
  --orange-glow: rgba(249,115,22,0.3);
  --gold: #ffd700;
  --gold-glow: rgba(255,215,0,0.3);
  --dark: #0f172a;
  --card-bg: #1e293b;
  --grey: #94a3b8;
  --red: #ef4444;
  --red-glow: rgba(239,68,68,0.3);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 100%; min-height: 100%;
  background: var(--dark);
  font-family: 'Nunito', sans-serif;
  color: #e2e8f0;
  user-select: none;
  -webkit-user-select: none;
}

body::before {
  content: '';
  position: fixed; inset: 0;
  background:
    radial-gradient(ellipse at 15% 20%, var(--teal-glow) 0%, transparent 50%),
    radial-gradient(ellipse at 85% 80%, var(--orange-glow) 0%, transparent 50%);
  pointer-events: none; z-index: 0;
}

/* ── Layout ── */
#app {
  position: relative; z-index: 1;
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center;
  padding: 0 16px 48px;
}

/* ── Header ── */
#header {
  width: 100%; text-align: center;
  padding: 18px 0 10px;
}
#header .label {
  font-size: 0.62em; letter-spacing: 0.22em;
  color: var(--grey); text-transform: uppercase;
}
#header h1 {
  font-size: 1.5em; font-weight: 900; margin: 4px 0 2px;
  background: linear-gradient(135deg, var(--teal), var(--gold), var(--orange));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
#header .subtitle { font-size: 0.78em; color: var(--grey); }

/* ── HUD ── */
#hud {
  display: flex; gap: 18px; align-items: center;
  font-size: 0.78em; font-weight: 700;
  margin-bottom: 14px;
}
#hud .hud-score { color: var(--teal); }
#hud .hud-round { color: var(--grey); }
#hud .hud-timer { color: var(--gold); font-variant-numeric: tabular-nums; }
#streak-wrap {
  display: flex; align-items: center; gap: 5px;
  color: var(--gold);
}
#streak-badge {
  display: inline-block; min-width: 28px; text-align: center;
  padding: 2px 8px; border-radius: 6px;
  background: rgba(255,215,0,0.12);
  border: 1px solid rgba(255,215,0,0.25);
  font-size: 1em; font-variant-numeric: tabular-nums;
  transition: transform 0.15s;
}
#streak-badge.bump { animation: streakBump 0.3s ease; }
@keyframes streakBump {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

/* ── Progress bar ── */
#progress-bar {
  width: 100%; max-width: 580px;
  height: 3px; background: rgba(255,255,255,0.08);
  border-radius: 2px; margin-bottom: 18px; overflow: hidden;
}
#progress-fill {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, var(--orange), var(--gold), var(--teal));
  border-radius: 2px; transition: width 0.4s ease;
}

/* ── Game card ── */
#game-card {
  width: 100%; max-width: 580px;
  background: rgba(30,41,59,0.9);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 18px;
  padding: 28px 24px 22px;
  text-align: center;
}

#instruction {
  font-size: 0.7em; text-transform: uppercase;
  letter-spacing: 0.15em; color: var(--grey);
  margin-bottom: 22px; line-height: 1.5;
}

/* ── Phrase display ── */
#phrase-display {
  display: flex; flex-wrap: wrap;
  align-items: center; justify-content: center;
  gap: 8px 6px; margin-bottom: 22px;
  min-height: 56px;
}

.phrase-word {
  font-size: 1.45em; font-weight: 800;
  color: var(--grey); letter-spacing: 0.02em;
}

.phrase-adj {
  font-size: 1.45em; font-weight: 800;
  padding: 6px 14px; border-radius: 10px;
  background: rgba(255,255,255,0.06);
  border: 2px solid rgba(255,255,255,0.1);
  color: #e2e8f0;
  cursor: pointer;
  letter-spacing: 0.02em;
  transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
}
.phrase-adj:hover {
  background: rgba(8,145,178,0.12);
  border-color: var(--teal);
  color: var(--teal);
  transform: translateY(-2px);
}
.phrase-adj:active { transform: translateY(0); }

.phrase-adj.flash-correct {
  background: rgba(8,145,178,0.22) !important;
  border-color: var(--teal) !important;
  color: var(--teal) !important;
  animation: adjCorrect 0.45s ease;
}
.phrase-adj.flash-wrong {
  background: rgba(249,115,22,0.18) !important;
  border-color: var(--orange) !important;
  color: var(--orange) !important;
  animation: adjWrong 0.4s ease;
}
@keyframes adjCorrect {
  0% { transform: scale(1); }
  40% { transform: scale(1.18); }
  100% { transform: scale(1); }
}
@keyframes adjWrong {
  0%,100% { transform: translateX(0); }
  20% { transform: translateX(-7px); }
  40% { transform: translateX(7px); }
  60% { transform: translateX(-5px); }
  80% { transform: translateX(4px); }
}

/* ── "Looks right!" button ── */
#btn-correct {
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(255,255,255,0.14);
  color: var(--grey);
  padding: 11px 26px; border-radius: 12px;
  font-family: 'Nunito', sans-serif;
  font-weight: 800; font-size: 0.9em;
  cursor: pointer;
  transition: all 0.18s ease;
  letter-spacing: 0.06em;
}
#btn-correct:hover {
  background: rgba(8,145,178,0.12);
  border-color: var(--teal);
  color: var(--teal);
}

/* ── Reveal panel ── */
#reveal-panel {
  width: 100%; max-width: 580px;
  margin-top: 14px;
  background: rgba(30,41,59,0.9);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px;
  padding: 16px 22px;
  text-align: center;
  display: none;
}
#reveal-panel.visible { display: block; animation: revealIn 0.3s ease; }
@keyframes revealIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
#reveal-phrase {
  font-size: 1.1em; font-weight: 800;
  color: var(--teal); margin-bottom: 6px;
}
#reveal-hint {
  font-size: 0.78em; color: var(--grey); line-height: 1.6;
  margin-bottom: 14px;
}
#btn-next {
  background: linear-gradient(135deg, var(--teal), var(--orange));
  border: none; color: white;
  padding: 10px 28px; border-radius: 10px;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 0.9em;
  cursor: pointer; transition: transform 0.15s, opacity 0.15s;
  letter-spacing: 0.05em;
}
#btn-next:hover { transform: scale(1.05); }
#btn-next:disabled { opacity: 0.3; cursor: default; transform: none; }

/* ── Streak milestone toast ── */
#milestone-toast {
  position: fixed; top: 20%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 35; font-size: 1.3em; font-weight: 900;
  pointer-events: none; opacity: 0;
  text-align: center; white-space: nowrap;
  color: var(--gold);
  text-shadow: 0 0 30px var(--gold-glow);
}
#milestone-toast.visible { animation: milestoneAnim 1.5s ease forwards; }
@keyframes milestoneAnim {
  0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.7); }
  20%  { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
  70%  { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -60%) scale(1); }
}

/* ── Feedback ── */
#feedback {
  position: fixed; top: 44%; left: 50%;
  transform: translate(-50%, -50%);
  z-index: 30; font-size: 1.7em; font-weight: 900;
  pointer-events: none; opacity: 0;
  transition: opacity 0.2s; text-align: center; white-space: nowrap;
}
#feedback.visible { opacity: 1; }
#feedback.correct { color: var(--teal); text-shadow: 0 0 30px var(--teal-glow); }
#feedback.wrong   { color: var(--orange); text-shadow: 0 0 30px var(--orange-glow); }
#feedback.timeout { color: var(--red); text-shadow: 0 0 30px var(--red-glow); }

/* ── Game over ── */
#game-over {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(15,23,42,0.96);
  display: none; flex-direction: column;
  align-items: center; justify-content: center;
  backdrop-filter: blur(10px);
  text-align: center; padding: 30px;
  gap: 4px;
}
#game-over.visible { display: flex; }
#game-over h2 {
  font-size: 2em; font-weight: 900; margin-bottom: 12px;
  background: linear-gradient(135deg, var(--teal), var(--gold), var(--orange));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
#game-over .summary {
  color: var(--grey); font-size: 0.95em; line-height: 2.1;
  margin-bottom: 24px;
}
#game-over .summary strong { color: #e2e8f0; }
#btn-restart {
  background: linear-gradient(135deg, var(--teal), var(--orange));
  border: none; color: white; padding: 14px 36px; border-radius: 12px;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 1em;
  cursor: pointer; transition: transform 0.2s;
}
#btn-restart:hover { transform: scale(1.05); }

/* ── Start overlay ── */
#start-overlay {
  position: fixed; inset: 0; z-index: 60;
  background: rgba(15,23,42,0.97);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  backdrop-filter: blur(10px);
  text-align: center; padding: 30px; gap: 16px;
}
#start-overlay h2 {
  font-size: 1.9em; font-weight: 900;
  background: linear-gradient(135deg, var(--teal), var(--gold), var(--orange));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
#start-overlay p {
  color: var(--grey); font-size: 0.9em;
  max-width: 380px; line-height: 1.7;
}
#start-overlay .rules {
  background: rgba(30,41,59,0.9);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px; padding: 16px 22px;
  text-align: left; max-width: 400px;
  font-size: 0.85em; line-height: 2;
  color: #cbd5e1;
}
#start-overlay .rules span.t { color: var(--teal); font-weight: 800; }
#start-overlay .rules span.o { color: var(--orange); font-weight: 800; }
#start-overlay .rules span.g { color: var(--gold); font-weight: 800; }
#btn-start {
  background: linear-gradient(135deg, var(--teal), var(--orange));
  border: none; color: white; padding: 14px 40px; border-radius: 12px;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 1em;
  cursor: pointer; transition: transform 0.2s;
}
#btn-start:hover { transform: scale(1.04); }

@media (min-width: 768px) {
  #header h1 { font-size: 1.9em; }
  .phrase-adj  { font-size: 1.65em; }
  .phrase-word { font-size: 1.65em; }
}
</style>
</head>
<body>

<!-- ── Start overlay ── -->
<div id="start-overlay">
  <h2>⚡ Error Correction Blitz</h2>
  <p>A noun phrase appears. One adjective might be in the wrong OSASCOMP position — <em>or the whole thing might be perfect</em>. You decide.</p>
  <div class="rules">
    <span class="t">Click the misplaced adjective</span> to flag the error<br>
    <span class="t">Click "✓ Looks right!"</span> if the order is perfect<br>
    <span class="o">Wrong answer</span> resets your streak<br>
    <span class="g">Streak bonus</span> — consecutive correct answers score more<br>
    <span class="g">Stopwatch</span> — race your classmates for the fastest time
  </div>
  <button id="btn-start">▶ Start</button>
</div>

<!-- ── Main app ── -->
<div id="app">
  <div id="header">
    <div class="label">CYE · OSASCOMP · GEII Year 2</div>
    <h1>⚡ Error Correction Blitz</h1>
    <div class="subtitle">Find the intruder — or confirm it's already perfect</div>
  </div>

  <div id="hud">
    <span class="hud-score">Score: <span id="score-val">0</span></span>
