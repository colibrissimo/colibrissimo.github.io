  },
  {
    tokens: [
      {t:'a',adj:false}, {t:'beautiful',adj:true,error:false,cat:'Opinion'},
      {t:'old-fashioned',adj:true,error:true,cat:'Age'}, {t:'tiny',adj:true,error:false,cat:'Size'},
      {t:'gadget',adj:false}
    ],
    hasError: true,
