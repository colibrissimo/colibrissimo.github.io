      {t:'a',adj:false}, {t:'holographic',adj:true,error:false,cat:'Opinion'},
      {t:'3D',adj:true,error:false,cat:'Shape'}, {t:'digital',adj:true,error:false,cat:'Purpose'},
      {t:'interface',adj:false}
    ],
    hasError: false,
    correct: 'a holographic 3D digital interface',
    hint: 'Opinion → Shape → Purpose — perfect order! ✓'
  }
];

// ═══════════════════════════════════════════════════════════════
//  State
// ═══════════════════════════════════════════════════════════════
let rounds, currentRound, score, streak, maxStreak, answered;
let stopwatchInterval, stopwatchMs = 0;

const MILESTONES = [
  { streak: 3,  msg: '🔥 3 in a row! +bonus' },
  { streak: 5,  msg: '⚡ 5 in a row! +bonus' },
  { streak: 8,  msg: '🏆 OSASCOMP MASTER! +bonus' },
];

// ═══════════════════════════════════════════════════════════════
//  Helpers
// ═══════════════════════════════════════════════════════════════
function $(id) { return document.getElementById(id); }

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function showFeedback(text, type) {
  const el = $('feedback');
  el.textContent = text;
  el.className = `visible ${type}`;
  setTimeout(() => { el.className = ''; }, 950);
}

function updateHUD() {
  $('score-val').textContent = score;
  $('round-cur').textContent = currentRound + 1;
  $('progress-fill').style.width = `${(currentRound / rounds.length) * 100}%`;
  const badge = $('streak-badge');
  badge.textContent = streak;
}

function bumpStreak() {
  const badge = $('streak-badge');
  badge.classList.remove('bump');
  void badge.offsetWidth;
  badge.classList.add('bump');
}

function showMilestone(msg) {
  const el = $('milestone-toast');
  el.textContent = msg;
  el.classList.remove('visible');
  void el.offsetWidth;
  el.classList.add('visible');
}

// ═══════════════════════════════════════════════════════════════
//  Stopwatch
// ═══════════════════════════════════════════════════════════════
function formatTime(ms) {
  const s = Math.floor(ms / 1000);
  return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
}

function startStopwatch() {
  stopwatchMs = 0;
  $('timer-val').textContent = '0:00';
  if (stopwatchInterval) clearInterval(stopwatchInterval);
  const start = Date.now();
  stopwatchInterval = setInterval(() => {
    stopwatchMs = Date.now() - start;
    $('timer-val').textContent = formatTime(stopwatchMs);
  }, 500);
}

function stopStopwatch() {
  clearInterval(stopwatchInterval);
}

// ═══════════════════════════════════════════════════════════════
//  Round lifecycle
// ═══════════════════════════════════════════════════════════════
function loadRound() {
  if (currentRound >= rounds.length) { endGame(); return; }
  const round = rounds[currentRound];
  answered = false;

  $('reveal-panel').classList.remove('visible');
  $('btn-next').disabled = true;

  const display = $('phrase-display');
  display.innerHTML = '';

  round.tokens.forEach(token => {
    if (token.adj) {
      const btn = document.createElement('button');
      btn.className = 'phrase-adj';
      btn.textContent = token.t;
      btn.addEventListener('click', () => onAdjClick(btn, token, round));
      display.appendChild(btn);
    } else {
      const span = document.createElement('span');
      span.className = 'phrase-word';
      span.textContent = token.t;
      display.appendChild(span);
    }
  });

  updateHUD();
}

function onAdjClick(btn, token, round) {
  if (answered) return;
  answered = true;

  if (round.hasError && token.error) {
    handleCorrect(round);
    btn.classList.add('flash-correct');
    showFeedback('✓ Found it!', 'correct');
  } else {
    handleWrong(round);
    btn.classList.add('flash-wrong');
    const msg = round.hasError ? '✗ Wrong adjective!' : '✗ No error here!';
    showFeedback(msg, 'wrong');
    revealError(round);
  }

  showReveal(round);
}

function onLooksRight(round) {
  if (answered) return;
  answered = true;

  if (!round.hasError) {
    handleCorrect(round);
    showFeedback('✓ Perfect order!', 'correct');
  } else {
    handleWrong(round);
    showFeedback('✗ There is an error!', 'wrong');
    revealError(round);
  }

  showReveal(round);
}

function handleCorrect(round) {
  const bonus = Math.min(streak * 2, 20);
  score += 10 + bonus;
  streak++;
  if (streak > maxStreak) maxStreak = streak;
  playCorrect();
  bumpStreak();
  updateHUD();
  const milestone = MILESTONES.find(m => m.streak === streak);
  if (milestone) {
    playMilestone();
    setTimeout(() => showMilestone(milestone.msg), 400);
  }
}

function handleWrong(round) {
  score = Math.max(0, score - 5);
  streak = 0;
  updateHUD();
}

function revealError(round) {
  if (!round.hasError) return;
  const adjBtns = $('phrase-display').querySelectorAll('.phrase-adj');
  const adjTokens = round.tokens.filter(t => t.adj);
  adjTokens.forEach((t, i) => {
    if (t.error) {
      setTimeout(() => adjBtns[i].classList.add('flash-correct'), 450);
    }
  });
}

function showReveal(round) {
  $('reveal-phrase').textContent = '✓ ' + round.correct;
  $('reveal-hint').textContent = round.hint;
  $('reveal-panel').classList.add('visible');
  setTimeout(() => { $('btn-next').disabled = false; }, 300);
}

function nextRound() {
  currentRound++;
  loadRound();
}

// ═══════════════════════════════════════════════════════════════
//  End game
// ═══════════════════════════════════════════════════════════════
function endGame() {
  stopStopwatch();
  $('progress-fill').style.width = '100%';
  playWin();
  $('go-summary').innerHTML =
    `Final score: <strong>${score}</strong><br>` +
    `Time: <strong>${formatTime(stopwatchMs)}</strong><br>` +
    `Best streak: <strong>${maxStreak}</strong>`;
  $('game-over').classList.add('visible');
}

// ═══════════════════════════════════════════════════════════════
//  Init
// ═══════════════════════════════════════════════════════════════
function init() {
  rounds = shuffle([...ROUNDS]);
  currentRound = 0;
  score = 0;
  streak = 0;
  maxStreak = 0;
  $('round-tot').textContent = rounds.length;
  $('game-over').classList.remove('visible');
  $('reveal-panel').classList.remove('visible');
  updateHUD();
  startStopwatch();
  loadRound();
}

// ═══════════════════════════════════════════════════════════════
//  Event listeners
// ═══════════════════════════════════════════════════════════════
$('btn-start').addEventListener('click', () => {
  $('start-overlay').style.display = 'none';
  init();
});

$('btn-correct').addEventListener('click', () => {
  if (!answered && rounds) onLooksRight(rounds[currentRound]);
});

$('btn-next').addEventListener('click', () => {
  if (!$('btn-next').disabled) nextRound();
});

$('btn-restart').addEventListener('click', () => {
  $('game-over').classList.remove('visible');
  init();
});

document.addEventListener('keydown', e => {
  if (!rounds) return;
  if (e.key === 'Enter' || e.key === ' ') {
    e.preventDefault();
    if (answered) { if (!$('btn-next').disabled) nextRound(); }
    else onLooksRight(rounds[currentRound]);
  }
});
</script>
</body>
</html>
